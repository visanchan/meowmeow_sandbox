# Copy to .env.local and fill in. .env.local is git-ignored.
# See docs/ENV_VARS.md for full reference. See docs/DEPLOYMENT.md for the Vercel side.

# Supabase --------------------------------------------------------
# Create a project at https://app.supabase.com, then Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRET — server only. Bypasses RLS. NEVER prefix with NEXT_PUBLIC_ or import from client components.
SUPABASE_SERVICE_ROLE_KEY=

# Resend ----------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
# Format: Display Name <address@domain>. Use onboarding@resend.dev for testing
# without verifying your own domain; switch to a verified domain for production.
EMAIL_FROM="Cat Booth POS <onboarding@resend.dev>"
# Inbox that receives new-application notifications (the founder's email).
ADMIN_EMAIL=

# Optional ---------------------------------------------------------
# Used by later batches for rate-limit / form analytics.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
